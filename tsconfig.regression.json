{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "outDir": "./tmp-regression",
    "incremental": false
  },
  "include": [
    "test-regression/run-regression.ts",
    "lib/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "tmp-regression", "test-regression/output"]
}
